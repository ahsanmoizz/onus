# ==============================================================================
# ONUS PROVIDER CONFIGURATION
# ==============================================================================
# Copy this file to your environment (e.g., export in ~/.bashrc or use a .env
# manager).  Do NOT commit filled-in secrets to version control.
#
# Usage:
#   set -o allexport; source config/examples/onus.env.example; set +o allexport
#   onus daemon
# ==============================================================================

# --- Provider selection -------------------------------------------------------
# Valid values: disabled, deterministic, local, cloud
#   disabled       — no semantic evaluation (static rules only)
#   deterministic  — built-in rule engine (no external call, offline safe)
#   local          — local subprocess (ollama, llama.cpp, etc.)
#   cloud          — remote OpenAI-compatible API
ONUS_SEMANTIC_PROVIDER=deterministic

# --- Cloud provider (only when ONUS_SEMANTIC_PROVIDER=cloud) ------------------
# ONUS_API_KEY=sk-placeholder-replace-with-your-key
# ONUS_API_ENDPOINT=https://api.openai.com/v1
# ONUS_MODEL=gpt-4o

# --- Local provider (only when ONUS_SEMANTIC_PROVIDER=local) ------------------
# ONUS_LOCAL_COMMAND=ollama run llama3

# --- Timeouts and limits ------------------------------------------------------
# ONUS_TIMEOUT_MS=5000
# ONUS_MAX_INPUT_BYTES=16384
# ONUS_TOKEN_BUDGET=4000

# --- Privacy ------------------------------------------------------------------
# Valid: strict, balanced, off
# ONUS_PRIVACY_MODE=balanced

# --- Data directory -----------------------------------------------------------
# ONUS_DATA_DIR=$HOME/.onus

# --- Daemon port --------------------------------------------------------------
# ONUS_LISTEN_PORT=4837
