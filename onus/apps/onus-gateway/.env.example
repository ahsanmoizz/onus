# Onus managed semantic gateway configuration.
# Copy this to .env on the VPS only. Never commit real values.

NODE_ENV=production
ONUS_GATEWAY_HOST=127.0.0.1
ONUS_GATEWAY_PORT=8080

# Server-side provider credentials. Users never receive this key.
ONUS_PROVIDER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
ONUS_PROVIDER_MODEL=qwen/qwen3-coder:free
ONUS_PROVIDER_API_KEY=replace_with_provider_key_on_vps
ONUS_PROVIDER_TIMEOUT_MS=30000
ONUS_PROVIDER_REFERER=https://ahsanmoizz.github.io/onus
ONUS_PROVIDER_TITLE=Onus

# Gateway auth. Generate long random values for production.
ONUS_REQUIRE_AUTH=1
ONUS_JWT_SECRET=replace_with_64_plus_random_chars
ONUS_ADMIN_TOKEN=replace_with_long_random_admin_token
ONUS_TOKEN_TTL_DAYS=30
ONUS_DAILY_REQUEST_LIMIT=500

# Postgres enables token revocation and usage limits.
ONUS_DATABASE_URL=postgresql://onus_user:replace_password@127.0.0.1:5432/onus
ONUS_REQUIRE_DATABASE=1

# CORS should include your Vercel production domain after deployment.
ONUS_ALLOWED_ORIGINS=https://ahsanmoizz.github.io,https://ahsanmoizz.github.io/onus,http://127.0.0.1:3000

# Safety limits.
ONUS_MAX_BODY_BYTES=65536
ONUS_MAX_RESPONSE_BYTES=262144

# Public activation is off by default to avoid abuse.
ONUS_ALLOW_PUBLIC_ACTIVATION=0
